# Copy this file to ".env" and fill in your Plaid keys.
# Get free keys at https://dashboard.plaid.com/signup  ->  Team Settings -> Keys

PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# Which Plaid environment to use:
#   sandbox     = fake test banks, no real money, free. START HERE.
#   production  = your real bank accounts (requires Plaid production access).
PLAID_ENV=sandbox

# Only needed for OAuth banks (e.g. Navy Federal, Chase). Must be an https URL
# registered in the Plaid dashboard (Developers -> API -> Allowed redirect URIs).
# For local dev use an https tunnel (ngrok) ending in /oauth.html. Leave blank otherwise.
PLAID_REDIRECT_URI=

# Port the local web app runs on.
PORT=4000
